modules = ["nodejs-20", "web", "python-3.11"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["libxcrypt", "rapidfuzz-cpp", "taskflow"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend (FastAPI)"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Frontend (Vite)"

[[workflows.workflow]]
name = "Backend (FastAPI)"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd cj-web/backend && python main.py"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Frontend (Vite)"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd cj-web/frontend && npm run dev"
waitForPort = 5173

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5173
externalPort = 5173

[[ports]]
localPort = 8000
externalPort = 80
